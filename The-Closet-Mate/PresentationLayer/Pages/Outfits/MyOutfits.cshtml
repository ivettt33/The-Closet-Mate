@page
@model PresentationLayer.Pages.Outfits.MyOutfitsModel
@{
    ViewData["Title"] = "My Outfits";
}

<div class="container my-5">
    <h2 class="text-pink text-center mb-4">My Created Outfits</h2>

    @if (Model.Outfits.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var outfit in Model.Outfits)
            {
                <div class="col">
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-pink text-white">
                            <strong>@outfit.Name</strong>
                        </div>

                        <div class="card-body d-flex flex-column justify-content-between">
                            <div class="d-flex flex-wrap gap-3 mb-3">
                                @foreach (var item in outfit.Items)
                                {
                                    <div style="width: 100px;">
                                        @if (!string.IsNullOrEmpty(item.ImagePath))
                                        {
                                            <img src="@item.ImagePath" alt="@item.Name" class="img-fluid rounded" style="height: 100px; object-fit: contain;" />
                                        }
                                        else
                                        {
                                            <div class="bg-light text-muted text-center d-flex align-items-center justify-content-center rounded"
                                                 style="width: 100px; height: 100px; font-size: 0.8rem;">
                                                No Image
                                            </div>
                                        }
                                        <p class="text-center small mt-1">@item.Name</p>
                                    </div>
                                }
                            </div>

                            <div class="d-flex justify-content-between mt-auto">
                                <a asp-page="/Outfits/EditOutfit" asp-route-id="@outfit.Id" class="btn btn-outline-primary btn-sm w-50 me-2">Edit</a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@outfit.Id" class="w-50" onsubmit="return confirm('Are you sure you want to delete this outfit?');">
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center mt-4">
            You haven't created any outfits yet. Start by creating one on the <a asp-page="/Outfits/Create">Create Outfit</a> page.
        </div>
    }
</div>
