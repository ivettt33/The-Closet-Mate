<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - The Closet Mate</title>


    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/individual_project.styles.css" asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display&family=Poppins:wght@400;600&display=swap" rel="stylesheet">

    @RenderSection("Styles", required: false)
</head>

<body>

    <div class="sidebar">
        <div class="app-title">The Closet Mate</div>

        <a asp-page="/Index"><i class="bi bi-house-door"></i> Home</a>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-page="/Wardrobe"><i class="bi bi-bag-check"></i> Wardrobe</a>
            <a asp-page="/Favorites"><i class="bi bi-heart-fill"></i> Favorites</a>
            <a asp-page="/Outfits/Create"><i class="bi bi-plus-square"></i> Create Outfit</a>
            <a asp-page="/Outfits/MyOutfits"><i class="bi bi-collection"></i> My Outfits</a>
            <a asp-page="/Planner"><i class="bi bi-calendar-week"></i> Planner</a>
        }

        <div class="bottom-links">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="text-muted small">Logged in as: @User.Identity.Name</div>
                <a asp-page="/Account/Logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
            }
            else
            {
                <a asp-page="/Account/Login"><i class="bi bi-box-arrow-in-right"></i> Login</a>
                <a asp-page="/Account/Register"><i class="bi bi-person-plus"></i> Register</a>
            }
        </div>
    </div>


    <div class="main-content">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
